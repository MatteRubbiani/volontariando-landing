---
// Footer.astro - Footer component
---

<footer id="contatti" class="bg-slate-50 border-t border-slate-200/50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
		<!-- Footer Grid -->
		<div class="grid md:grid-cols-5 gap-10 mb-12">
			<!-- Brand Column -->
			<div>
				<div class="flex items-center gap-2 mb-6">
					<div class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-600 to-blue-600 flex items-center justify-center">
						<span class="text-white font-black text-sm">V</span>
					</div>
					<span class="font-black text-lg text-slate-900">Volontariando</span>
				</div>
				<p class="text-slate-600 text-sm leading-relaxed">
					Connettendo volontari, associazioni e aziende per un impatto sociale tangibile e misurabile.
				</p>
				<!-- Social Links -->
				<div class="flex gap-4 mt-6">
					<a href="#" class="w-10 h-10 rounded-lg bg-slate-200 hover:bg-emerald-600 text-slate-600 hover:text-white transition-all flex items-center justify-center group">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
						</svg>
					</a>
					<a href="#" class="w-10 h-10 rounded-lg bg-slate-200 hover:bg-blue-600 text-slate-600 hover:text-white transition-all flex items-center justify-center group">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7"></path>
						</svg>
					</a>
					<a href="#" class="w-10 h-10 rounded-lg bg-slate-200 hover:bg-blue-600 text-slate-600 hover:text-white transition-all flex items-center justify-center group">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path>
							<circle cx="4" cy="4" r="2"></circle>
						</svg>
					</a>
					<a href="#" class="w-10 h-10 rounded-lg bg-slate-200 hover:bg-slate-700 text-slate-600 hover:text-white transition-all flex items-center justify-center group">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
						</svg>
					</a>
				</div>
			</div>

			<!-- For Volunteers -->
			<div>
				<h4 class="font-black text-slate-900 mb-6">Per Volontari</h4>
				<ul class="space-y-3">
					<li><a href="#" class="text-slate-600 hover:text-emerald-600 transition-colors text-sm font-medium">Scopri Cause</a></li>
					<li><a href="#" class="text-slate-600 hover:text-emerald-600 transition-colors text-sm font-medium">Le Mie Candidature</a></li>
					<li><a href="#" class="text-slate-600 hover:text-emerald-600 transition-colors text-sm font-medium">Dashboard</a></li>
					<li><a href="#" class="text-slate-600 hover:text-emerald-600 transition-colors text-sm font-medium">Certificati</a></li>
					<li><a href="#" class="text-slate-600 hover:text-emerald-600 transition-colors text-sm font-medium">Community</a></li>
				</ul>
			</div>

			<!-- For Organizations -->
			<div>
				<h4 class="font-black text-slate-900 mb-6">Per Associazioni</h4>
				<ul class="space-y-3">
					<li><a href="#" class="text-slate-600 hover:text-blue-600 transition-colors text-sm font-medium">Crea Progetto</a></li>
					<li><a href="#" class="text-slate-600 hover:text-blue-600 transition-colors text-sm font-medium">Gestisci Team</a></li>
					<li><a href="#" class="text-slate-600 hover:text-blue-600 transition-colors text-sm font-medium">Analytics</a></li>
					<li><a href="#" class="text-slate-600 hover:text-blue-600 transition-colors text-sm font-medium">Risorse</a></li>
					<li><a href="#" class="text-slate-600 hover:text-blue-600 transition-colors text-sm font-medium">Supporto</a></li>
				</ul>
			</div>

			<!-- For Companies -->
			<div>
				<h4 class="font-black text-slate-900 mb-6">Per Aziende</h4>
				<ul class="space-y-3">
					<li><a href="#" class="text-slate-600 hover:text-violet-600 transition-colors text-sm font-medium">Programmi ESG</a></li>
					<li><a href="#" class="text-slate-600 hover:text-violet-600 transition-colors text-sm font-medium">Metriche e Report</a></li>
					<li><a href="#" class="text-slate-600 hover:text-violet-600 transition-colors text-sm font-medium">Case Studies</a></li>
					<li><a href="#" class="text-slate-600 hover:text-violet-600 transition-colors text-sm font-medium">Pricing</a></li>
					<li><a href="#" class="text-slate-600 hover:text-violet-600 transition-colors text-sm font-medium">Contatti Commerciali</a></li>
				</ul>
			</div>

			<!-- Company -->
			<div>
				<h4 class="font-black text-slate-900 mb-6">Azienda</h4>
				<ul class="space-y-3">
					<li><a href="#" class="text-slate-600 hover:text-slate-900 transition-colors text-sm font-medium">About Us</a></li>
					<li><a href="#" class="text-slate-600 hover:text-slate-900 transition-colors text-sm font-medium">Blog</a></li>
					<li><a href="#" class="text-slate-600 hover:text-slate-900 transition-colors text-sm font-medium">Carriere</a></li>
					<li><a href="#" class="text-slate-600 hover:text-slate-900 transition-colors text-sm font-medium">Privacy Policy</a></li>
					<li><a href="#" class="text-slate-600 hover:text-slate-900 transition-colors text-sm font-medium">Terms of Service</a></li>
				</ul>
			</div>
		</div>

		<!-- Newsletter Signup -->
		<div class="rounded-2xl bg-gradient-to-r from-emerald-50 to-blue-50 border border-emerald-200/50 p-8 md:p-10 mb-12">
			<div class="grid md:grid-cols-2 gap-8 items-center">
				<div>
					<h3 class="text-2xl font-black text-slate-900 mb-3">Rimani Aggiornato</h3>
					<p class="text-slate-600">Ricevi le ultime notizie su nuove cause, iniziative e storie di impatto.</p>
				</div>
				<form class="flex gap-2">
					<input 
						type="email" 
						placeholder="La tua email" 
						class="flex-1 px-4 py-3 rounded-lg bg-white border border-slate-200 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-600"
					/>
					<button
						type="submit"
						class="px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:scale-105 transition-all duration-200 hover:shadow-lg hover:shadow-emerald-200"
					>
						Subscribe
					</button>
				</form>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div class="border-t border-slate-200/50 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
			<p class="text-slate-600 text-sm">
				© 2024 Volontariando. Tutti i diritti riservati.
			</p>
			<div class="flex gap-6 text-sm">
				<a href="#" class="text-slate-600 hover:text-slate-900 transition-colors">Privacy</a>
				<a href="#" class="text-slate-600 hover:text-slate-900 transition-colors">Termini</a>
				<a href="#" class="text-slate-600 hover:text-slate-900 transition-colors">Cookie</a>
				<a href="#" class="text-slate-600 hover:text-slate-900 transition-colors">Status</a>
			</div>
		</div>
	</div>
</footer>
