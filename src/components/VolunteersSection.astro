---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const registrationUrl = 'https://app.volontariando.it/auth/registrazione';
---

<section id="volontari" class="relative w-full min-h-[100svh] flex flex-col items-center justify-center pt-24 pb-8 overflow-hidden bg-slate-50">
	<div class="w-full max-w-7xl mx-auto px-6 lg:px-8">
		<div class="max-w-3xl">
			<p class="reveal-on-scroll text-[10px] font-black uppercase tracking-widest text-emerald-600 transition-all duration-1000 ease-out">{t.volunteers.eyebrow}</p>
			<h2 class="reveal-on-scroll mt-4 text-3xl font-black tracking-tight text-slate-900 transition-all duration-1000 ease-out delay-100 sm:text-5xl">
				{t.volunteers.title}
			</h2>
			<p class="reveal-on-scroll mt-5 max-w-2xl text-lg font-medium leading-relaxed text-slate-600 transition-all duration-1000 ease-out delay-200">
				{t.volunteers.description}
			</p>
		</div>

		<div class="mt-12 grid gap-5 md:grid-cols-3">
			<article class="reveal-on-scroll rounded-3xl border border-emerald-200 bg-white p-7 transition-all duration-1000 ease-out delay-100">
				<p class="text-[10px] font-black uppercase tracking-widest text-emerald-700">{t.volunteers.cards[0].eyebrow}</p>
				<h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{t.volunteers.cards[0].title}</h3>
				<p class="mt-3 text-sm font-medium leading-relaxed text-slate-600">
					{t.volunteers.cards[0].description}
				</p>
			</article>

			<article class="reveal-on-scroll rounded-3xl border border-emerald-200 bg-emerald-50/70 p-7 transition-all duration-1000 ease-out delay-200">
				<p class="text-[10px] font-black uppercase tracking-widest text-emerald-700">{t.volunteers.cards[1].eyebrow}</p>
				<h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{t.volunteers.cards[1].title}</h3>
				<p class="mt-3 text-sm font-medium leading-relaxed text-slate-600">
					{t.volunteers.cards[1].description}
				</p>
			</article>

			<article class="reveal-on-scroll rounded-3xl border border-slate-200 bg-white p-7 transition-all duration-1000 ease-out delay-300">
				<p class="text-[10px] font-black uppercase tracking-widest text-slate-500">{t.volunteers.cards[2].eyebrow}</p>
				<h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{t.volunteers.cards[2].title}</h3>
				<p class="mt-3 text-sm font-medium leading-relaxed text-slate-500">{t.volunteers.cards[2].description}</p>
			</article>
		</div>

		<div class="reveal-on-scroll mt-10 transition-all duration-1000 ease-out delay-400">
			<a
				href={registrationUrl}
				class="inline-flex items-center rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-[0_10px_30px_rgba(16,185,129,0.24)] transition-transform duration-300 hover:scale-[1.02]"
			>
				{t.volunteers.cta}
			</a>
		</div>
	</div>
</section>
