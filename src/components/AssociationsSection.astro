---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const registrationUrl = 'https://app.volontariando.it/auth/registrazione';
---

<section id="associazioni" class="relative w-full min-h-[100svh] flex flex-col items-center justify-center pt-24 pb-8 overflow-hidden bg-white">
	<div class="w-full max-w-7xl mx-auto px-6 lg:px-8">
		<div class="max-w-3xl">
			<p class="reveal-on-scroll text-[10px] font-black uppercase tracking-widest text-blue-600 transition-all duration-1000 ease-out">{t.associations.eyebrow}</p>
			<h2 class="reveal-on-scroll mt-4 text-3xl font-black tracking-tight text-slate-900 transition-all duration-1000 ease-out delay-100 sm:text-5xl">
				{t.associations.title}
			</h2>
			<p class="reveal-on-scroll mt-5 max-w-2xl text-lg font-medium leading-relaxed text-slate-600 transition-all duration-1000 ease-out delay-200">
				{t.associations.description}
			</p>
		</div>

		<div class="mt-12 grid gap-5 md:grid-cols-3">
			<article class="reveal-on-scroll rounded-3xl border border-blue-200 bg-slate-50 p-7 transition-all duration-1000 ease-out delay-100">
				<p class="text-[10px] font-black uppercase tracking-widest text-blue-700">{t.associations.cards[0].eyebrow}</p>
				<h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{t.associations.cards[0].title}</h3>
				<p class="mt-3 text-sm font-medium leading-relaxed text-slate-600">{t.associations.cards[0].description}</p>
			</article>

			<article class="reveal-on-scroll rounded-3xl border border-blue-200 bg-blue-50/70 p-7 transition-all duration-1000 ease-out delay-200">
				<p class="text-[10px] font-black uppercase tracking-widest text-blue-700">{t.associations.cards[1].eyebrow}</p>
				<h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{t.associations.cards[1].title}</h3>
				<p class="mt-3 text-sm font-medium leading-relaxed text-slate-600">{t.associations.cards[1].description}</p>
			</article>

			<article class="reveal-on-scroll rounded-3xl border border-slate-200 bg-white p-7 transition-all duration-1000 ease-out delay-300">
				<p class="text-[10px] font-black uppercase tracking-widest text-slate-500">{t.associations.cards[2].eyebrow}</p>
				<h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{t.associations.cards[2].title}</h3>
				<p class="mt-3 text-sm font-medium leading-relaxed text-slate-500">{t.associations.cards[2].description}</p>
			</article>
		</div>

		<div class="reveal-on-scroll mt-10 transition-all duration-1000 ease-out delay-400">
			<a
				href={registrationUrl}
				class="inline-flex items-center rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-[0_10px_30px_rgba(37,99,235,0.24)] transition-transform duration-300 hover:scale-[1.02]"
			>
				{t.associations.cta}
			</a>
		</div>
	</div>
</section>
