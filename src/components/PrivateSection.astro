---
// PrivateSection.astro - Section for volunteers and associations - Tailwind v4
---

<section id="per-volontari" class="py-20 md:py-32 bg-linear-to-br from-slate-50 to-emerald-50/30">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="text-center mb-16 md:mb-20">
			<h2 class="text-slate-900 mb-4 font-black tracking-tight text-3xl md:text-4xl lg:text-5xl">
				<span class="block">Per Volontari e</span>
				<span class="block bg-linear-to-r from-emerald-600 to-blue-600 bg-clip-text text-transparent">Associazioni</span>
			</h2>
			<p class="max-w-2xl mx-auto text-lg text-slate-600 mt-6">
				Scopri cosa rende Volontariando la piattaforma ideale per amplificare il tuo impatto sociale
			</p>
		</div>

		<!-- Features Grid -->
		<div class="grid md:grid-cols-3 gap-8 mb-12">
			<!-- Feature 1: Esplora -->
			<div class="group rounded-3xl bg-white border border-emerald-100/50 p-8 md:p-10 hover:scale-105 transition-all duration-300 hover:shadow-2xl hover:shadow-emerald-100">
				<!-- Icon Container -->
				<div class="w-14 h-14 rounded-2xl bg-linear-to-br from-emerald-100 to-emerald-50 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"></path>
					</svg>
				</div>

				<!-- Title -->
				<h3 class="text-xl font-black text-slate-900 mb-3">Esplora Cause</h3>

				<!-- Description -->
				<p class="text-slate-600 leading-relaxed mb-6">
					Scopri centinaia di cause e progetti selezionati da associazioni verificate. 
					Filtra per categorie, location e impact areas che ti interessano.
				</p>

				<!-- Link with arrow -->
				<div class="flex items-center text-emerald-600 font-semibold text-sm group-hover:translate-x-1 transition-transform">
					Scopri di più
					<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</div>
			</div>

			<!-- Feature 2: Candidati -->
			<div class="group rounded-3xl bg-white border border-blue-100/50 p-8 md:p-10 hover:scale-105 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100">
				<!-- Icon Container -->
				<div class="w-14 h-14 rounded-2xl bg-linear-to-br from-blue-100 to-blue-50 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l4-6m-4 6l-4-6"></path>
					</svg>
				</div>

				<!-- Title -->
				<h3 class="text-xl font-black text-slate-900 mb-3">Candidati e Partecipa</h3>

				<!-- Description -->
				<p class="text-slate-600 leading-relaxed mb-6">
					Manda e gestisci le tue candidature. Ricevi notifiche dei progetti che matchano il tuo profilo 
					e coordina gli orari con altri volontari.
				</p>

				<!-- Link with arrow -->
				<div class="flex items-center text-blue-600 font-semibold text-sm group-hover:translate-x-1 transition-transform">
					Candidati
					<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</div>
			</div>

			<!-- Feature 3: Traccia Impatto -->
			<div class="group rounded-3xl bg-white border border-emerald-100/50 p-8 md:p-10 hover:scale-105 transition-all duration-300 hover:shadow-2xl hover:shadow-emerald-100">
				<!-- Icon Container -->
				<div class="w-14 h-14 rounded-2xl bg-linear-to-br from-emerald-100 to-emerald-50 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
					</svg>
				</div>

				<!-- Title -->
				<h3 class="text-xl font-black text-slate-900 mb-3">Traccia il Tuo Impatto</h3>

				<!-- Description -->
				<p class="text-slate-600 leading-relaxed mb-6">
					Visualizza ore donate, persone aiutate, e tanto altro. Condividi il tuo contributo 
					su profilo pubblico e celebra i tuoi traguardi.
				</p>

				<!-- Link with arrow -->
				<div class="flex items-center text-emerald-600 font-semibold text-sm group-hover:translate-x-1 transition-transform">
					View Dashboard
					<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</div>
			</div>
		</div>

		<!-- Benefits Sub-Section -->
		<div class="mt-16 md:mt-24 grid md:grid-cols-2 gap-10">
			<!-- Left column - Benefits list -->
			<div class="space-y-4">
				<h3 class="text-2xl font-black text-slate-900 mb-8">Perché scegliere Volontariando?</h3>
				
				<div class="flex gap-4">
					<div class="shrink-0">
						<div class="flex items-center justify-center h-6 w-6 rounded-md bg-emerald-600">
							<svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
							</svg>
						</div>
					</div>
					<div>
						<p class="text-slate-700 font-semibold">Associazioni verificate e trasparenti</p>
						<p class="text-slate-600 text-sm mt-1">Solo partner seri e riconosciuti</p>
					</div>
				</div>

				<div class="flex gap-4">
					<div class="shrink-0">
						<div class="flex items-center justify-center h-6 w-6 rounded-md bg-blue-600">
							<svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
							</svg>
						</div>
					</div>
					<div>
						<p class="text-slate-700 font-semibold">Matching intelligente di volunteer skills</p>
						<p class="text-slate-600 text-sm mt-1">Trova progetti che valorizzano le tue competenze</p>
					</div>
				</div>

				<div class="flex gap-4">
					<div class="shrink-0">
						<div class="flex items-center justify-center h-6 w-6 rounded-md bg-emerald-600">
							<svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
							</svg>
						</div>
					</div>
					<div>
						<p class="text-slate-700 font-semibold">Community di supporto mutuo</p>
						<p class="text-slate-600 text-sm mt-1">Connettiti con volontari che condividono i tuoi valori</p>
					</div>
				</div>

				<div class="flex gap-4">
					<div class="shrink-0">
						<div class="flex items-center justify-center h-6 w-6 rounded-md bg-blue-600">
							<svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
							</svg>
						</div>
					</div>
					<div>
						<p class="text-slate-700 font-semibold">Certificati e riconoscimenti</p>
						<p class="text-slate-600 text-sm mt-1">Valorizza il tuo ruolo nei tuoi CV e profili sociali</p>
					</div>
				</div>
			</div>

			<!-- Right column - Image / Visual -->
			<div class="rounded-3xl bg-linear-to-br from-emerald-100/40 to-blue-100/40 border border-emerald-200/30 p-12 flex items-center justify-center min-h-80">
				<div class="text-center">
					<div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white border-4 border-emerald-200 mb-4">
						<svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2 1m2-1l-2-1m2 1v2.5"></path>
						</svg>
					</div>
					<p class="text-slate-600 font-semibold">Manage Your Impact</p>
					<p class="text-sm text-slate-500 mt-2">Dashboard intuitivo</p>
				</div>
			</div>
		</div>

		<!-- CTA Button -->
		<div class="text-center mt-16">
			<a href="https://app.volontariando.it" class="inline-flex items-center justify-center px-8 py-3.5 bg-emerald-600 text-white font-bold rounded-xl hover:scale-105 transition-all duration-200 hover:shadow-lg hover:shadow-emerald-200">
				Inizia Ora - È Gratuito
				<svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
				</svg>
			</a>
		</div>
	</div>
</section>
