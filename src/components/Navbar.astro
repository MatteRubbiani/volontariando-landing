---
// Navbar.astro - Sticky header component with Tailwind v4
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/80 border-b border-slate-200/50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16">
			<!-- Logo -->
			<div class="flex-shrink-0 flex items-center">
				<a href="/" class="flex items-center gap-2">
					<div class="w-8 h-8 rounded-lg bg-linear-to-br from-emerald-600 to-blue-600 flex items-center justify-center">
						<span class="text-white font-black text-sm">V</span>
					</div>
					<span class="font-black text-lg text-slate-900">Volontariando</span>
				</a>
			</div>

			<!-- Navigation Links - Hidden on mobile -->
			<div class="hidden md:flex items-center gap-8">
				<a href="#per-volontari" class="text-slate-600 hover:text-emerald-600 transition-colors font-medium text-sm">Per Volontari</a>
				<a href="#per-aziende" class="text-slate-600 hover:text-violet-600 transition-colors font-medium text-sm">Per Aziende</a>
				<a href="#statistiche" class="text-slate-600 hover:text-slate-900 transition-colors font-medium text-sm">Impatto</a>
				<a href="#contatti" class="text-slate-600 hover:text-slate-900 transition-colors font-medium text-sm">Contatti</a>
			</div>

			<!-- CTA Buttons -->
			<div class="flex items-center gap-3">
				<button class="hidden sm:inline-flex px-4 py-2 text-slate-700 font-medium text-sm hover:text-slate-900 transition-colors">
					Accedi
				</button>
				<button class="px-4 py-2 bg-emerald-600 text-white font-semibold text-sm rounded-lg hover:scale-105 transition-all duration-200 hover:shadow-lg hover:shadow-emerald-200">
					Registrati
				</button>

				<!-- Mobile Menu Button -->
				<button class="md:hidden inline-flex items-center justify-center w-8 h-8 rounded-md text-slate-600 hover:bg-slate-100 transition-colors">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
				</button>
			</div>
		</div>
	</div>
</nav>

<!-- Spacer per il fixed navbar -->
<div class="h-16"></div>
